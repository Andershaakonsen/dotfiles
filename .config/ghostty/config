# Ghostty config — mirrors .config/kitty/kitty.conf for side-by-side comparison.
# See scripts/tmux-kitty-tint.sh: kitty's per-session bg tint uses kitty remote
# control and has NO Ghostty equivalent, so that effect won't apply here.

# Fonts
font-family = "JetBrainsMono Nerd Font"
font-size = 22

# Window
background-opacity = 1.0
window-decoration = false
window-padding-x = 10
window-padding-y = 0
confirm-close-surface = false

# Colors — auto-switch with macOS appearance: Mocha (dark) / Latte (light),
# matching the Neovim colorscheme.lua light/dark setup.
theme = dark:Catppuccin Mocha,light:Catppuccin Latte
# Custom selection/cursor to match kitty's overrides
selection-foreground = 1e1e2e
selection-background = f5e0dc
cursor-color = f5e0dc

# Cursor / shell integration
cursor-style = block
shell-integration-features = no-cursor

# macOS
# macos-option-as-alt disabled so right/left Option composes å/ø/æ again.
# Trade-off: alt+<key> bindings (e.g. herdr-splits resize) won't reach apps here.
macos-titlebar-style = hidden

# Keybind: new OS window with cwd (kitty: super+shift+enter)
keybind = super+shift+enter=new_window
