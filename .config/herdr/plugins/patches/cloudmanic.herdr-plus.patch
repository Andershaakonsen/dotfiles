+// workspaceList returns every currently-open workspace with its id and label.
+// openProject uses it to find a workspace a project already opened (matched by
+// label) so it can switch to it instead of creating a duplicate — the
+// tmux-sessionizer behavior.
+func (c *herdrClient) workspaceList() ([]workspaceInfo, error) {
+	var out struct {
+		Workspaces []workspaceInfo `json:"workspaces"`
+	}
+	if err := c.call("workspace.list", map[string]any{}, &out); err != nil {
+		return nil, err
+	}
+	return out.Workspaces, nil
+}
+
+// workspaceFocus switches the user to an existing workspace, making it the
+// active one. It is the "go to the workspace that is already open" half of the
+// sessionizer behavior — the counterpart to workspaceCreate.
+func (c *herdrClient) workspaceFocus(workspaceID string) error {
+	return c.call("workspace.focus", map[string]any{"workspace_id": workspaceID}, nil)
+}
+
+// tabFocus makes tabID the active tab of its workspace (and focuses it).
+// runProjectsUI uses it to re-activate the launching tab before this process
+// exits and herdr tears the picker's tab down: herdr's plugin-pane teardown
+// otherwise activates the picker tab's neighbor rather than the tab you
+// launched from, so a switch-and-return (or a stay) lands on the wrong tab.
+func (c *herdrClient) tabFocus(tabID string) error {
+	return c.call("tab.focus", map[string]any{"tab_id": tabID}, nil)
+}
+
 // workspaceCreate makes a brand-new workspace rooted at cwd with the given
 // label, and returns the ids of the new workspace, its single root tab, and
 // that tab's root pane. When focus is true the workspace becomes the active one
