index 0000000..db1e7d7
--- /dev/null
+++ b/zoomrestore.go
@@ -0,0 +1,111 @@
+//
+// Local patch (not upstream): restore a zoomed pane after the Projects picker
+// closes. Opening the picker as a plugin pane in the caller's tab and then
+// tearing it down makes herdr recompute the tab layout and drop the tab's
+// zoom — so a `prefix+f` from a zoomed pane lands you un-zoomed. herdr does
+// this on the picker's teardown regardless of placement ("zoomed" or
+// "overlay"), so it can't be fixed from herdr-plugin.toml alone.
+//
+// launchProjects records the launching pane and whether it was zoomed, then
+// (when it was) spawns `herdr-plus restore-zoom <picker> <caller>` detached.
+// That watcher waits for the picker pane to disappear and re-applies zoom to
+// the caller pane. It runs detached so it outlives launchProjects and any
+// timeout herdr might place on an action command. All best-effort: any failure
+// just leaves the zoom as-is.
+//
+
+package main
+
+import (
+	"encoding/json"
+	"os"
+	"os/exec"
+	"time"
+)
+
+// herdrBin resolves the herdr CLI. herdr injects HERDR_BIN_PATH into plugin
+// commands; fall back to PATH lookup otherwise.
+func herdrBin() string {
+	if b := os.Getenv("HERDR_BIN_PATH"); b != "" {
+		return b
+	}
+	return "herdr"
+}
+
+// paneExists reports whether a pane is still present. `herdr pane get` exits
+// non-zero with a pane_not_found error once the pane is gone.
+func paneExists(herdr, paneID string) bool {
+	return exec.Command(herdr, "pane", "get", paneID).Run() == nil
+}
+
+// paneZoomed reports whether the tab containing paneID is currently zoomed.
+// `herdr pane layout --pane` returns the pane's tab layout, whose top-level
+// `zoomed` flag is what we toggle. A missing pane or parse failure reads as
+// not-zoomed, which is safe: the caller only ever re-applies zoom.
+func paneZoomed(herdr, paneID string) bool {
+	out, err := exec.Command(herdr, "pane", "layout", "--pane", paneID).Output()
+	if err != nil {
+		return false
+	}
+	var resp struct {
+		Result struct {
+			Layout struct {
+				Zoomed bool `json:"zoomed"`
+			} `json:"layout"`
+		} `json:"result"`
+	}
+	if json.Unmarshal(out, &resp) != nil {
+		return false
+	}
+	return resp.Result.Layout.Zoomed
+}
+
+// spawnRestoreZoom launches the detached watcher that re-zooms callerPane once
+// pickerPane closes. It returns immediately; the child is not waited on.
+func spawnRestoreZoom(herdr, pickerPane, callerPane string) {
+	self, err := os.Executable()
+	if err != nil {
+		return
+	}
+	cmd := exec.Command(self, "restore-zoom", pickerPane, callerPane)
+	// Detach: don't tie the child's lifetime or stdio to this process.
+	cmd.Stdin, cmd.Stdout, cmd.Stderr = nil, nil, nil
+	_ = cmd.Start()
+	if cmd.Process != nil {
+		_ = cmd.Process.Release()
+	}
+}
+
+// runRestoreZoom is the detached watcher (the `restore-zoom` subcommand). It
+// waits for pickerPane to close, then re-applies zoom to callerPane, retrying a
+// few times to win the race with herdr's teardown-driven unzoom.
+func runRestoreZoom(args []string) {
+	if len(args) < 2 {
+		return
+	}
+	pickerPane, callerPane := args[0], args[1]
+	herdr := herdrBin()
+
+	// Wait for the picker to close. Bounded so an abandoned picker doesn't poll
+	// forever; on timeout we just skip the restore.
+	deadline := time.Now().Add(30 * time.Minute)
+	for time.Now().Before(deadline) {
+		if !paneExists(herdr, pickerPane) {
+			break
+		}
+		time.Sleep(250 * time.Millisecond)
+	}
+
+	// herdr's unzoom happens as part of the teardown; give it a beat to settle,
+	// then re-zoom. Retry a few times in case teardown lands after our first try.
+	for i := 0; i < 5; i++ {
+		time.Sleep(200 * time.Millisecond)
+		if !paneExists(herdr, callerPane) {
+			return // nothing left to restore
+		}
+		if paneZoomed(herdr, callerPane) {
+			return // already zoomed (restored, or user never lost it)
+		}
+		_ = exec.Command(herdr, "pane", "zoom", "--pane", callerPane, "--on").Run()
+	}
+}
